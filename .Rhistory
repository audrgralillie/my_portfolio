packageVersion("tmap")
nrow(detroit_dots)
library(tidycensus)
library(tigris)
library(tmap)
library(sf)
library(dplyr)
library(ggplot2)
library(dplyr)
library(stringr)
library(tidyverse)
# dot-density maps
tmap_mode("plot")
detroit_race <- get_decennial(
geography = "tract",
state = "MI",
county = "Wayne",
variables = c(
Hispanic = "P2_002N",
White = "P2_005N",
Black = "P2_006N",
Native = "P2_007N",
Asian = "P2_008N"
),
summary_var = "P2_001N",
year = 2020,
geometry = TRUE
) %>%
mutate(percent = 100 * (value / summary_value))
detroit_race <- detroit_race %>%
filter(value >= 100)
detroit_dots <- detroit_race %>%
as_dot_density(
value = "value",
values_per_dot = 2000,
group = "variable"
)
nrow(detroit_dots)
head(detroit_dots)
packageVersion("tmap")
nrow(detroit_dots)
class(detroit_dots)
background_tracts <- filter(detroit_race, variable == "White")
race_map <- tm_shape(background_tracts) +
tm_polygons(col = "white",
border.col = "grey") +
tm_shape(detroit_dots) +
tm_dots(col = "variable",
palette = "Set1",
size = 0.1,
title = "1 dot = 100 people") +
tm_layout(legend.outside = TRUE,
title = "Race/ethnicity,\n2020 US Census")
race_map
names(dtown.tracts)
dtown.tracts <- large.tracts %>%
filter(NAME == "Detroit") %>%
mutate(
blklq   = (black / tpop) / (blackc / tpopc),
asnlq   = (asian / tpop) / (asianc / tpopc),
hisplq  = (hisp / tpop) / (hispc / tpopc),
whitelq = (white / tpop) / (whitec / tpopc)
)
#| label: setup
#| include: false
options(tigris_use_cache = TRUE)
options(tigris_progress = FALSE)
library(tidycensus)
library(tigris)
library(tmap)
library(sf)
library(dplyr)
library(ggplot2)
library(dplyr)
library(stringr)
library(tidyverse)
library(sf)
library(rmapshaper)
library(flextable)
dtown.tracts <- large.tracts %>%
filter(NAME == "Detroit") %>%
mutate(
blklq   = (black / tpop) / (blackc / tpopc),
asnlq   = (asian / tpop) / (asianc / tpopc),
hisplq  = (hisp / tpop) / (hispc / tpopc),
whitelq = (white / tpop) / (whitec / tpopc)
)
quarto publish quarto-pub
quarto publish gh-pages
