## "Young" Population Dispersion

```{r}
#| echo: false
#| message: false
#| warning: false
young_denver <- get_decennial(
  geography = "tract",
  variables = "P1_004N",
  state = "CO",
  county = "Denver",
  geometry = TRUE,
  year = 2020
)

young_centroids <- st_centroid(young_denver)

tm_shape(young_denver) +
  tm_polygons(col = "white", border.col = "grey") +
  tm_shape(young_centroids) +
  tm_symbols(
    size = "value",
    col = "navy"
  )
```
